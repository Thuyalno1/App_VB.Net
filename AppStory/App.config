<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <connectionStrings>
        <!--
            ODBC DSN-less connection string cho MySQL.
            Thay tên Driver nếu cần: MySQL ODBC 8.0 Unicode Driver hoặc MySQL ODBC 9.0 Unicode Driver
            (Kiểm tra tên driver đã cài: Control Panel > ODBC Data Sources > Drivers tab)
            server   = địa chỉ MySQL (thường là localhost)
            port     = cổng MySQL (mặc định 3306)
            database = tên database
            uid      = tên người dùng MySQL
            pwd      = mật khẩu MySQL
        -->
        <add name="AppStoryDB"
             connectionString="Driver={MySQL ODBC 9.6 Unicode Driver};Server=localhost;Port=3306;Database=appstore;Uid=root;Pwd=thuymv;charset=utf8;"
             providerName="System.Data.Odbc" />
    </connectionStrings>
</configuration>